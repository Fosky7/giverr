# Giverr frontend environment
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real secrets.

# Supabase project URL used by the browser client and typed campaign API wrappers.
# Example: https://your-project-ref.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public key used by the browser client.
# This key is safe to expose in the browser when Row Level Security policies are enabled.
VITE_SUPABASE_ANON_KEY=
